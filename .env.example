# Database
DATABASE_URL=postgresql://cyberdestiny:cyberdestiny_dev@localhost:5432/cyberdestiny

# API
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
WEB_URL=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# LLM (optional — mock interpreter used when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Billing (Phase 2+)
DEFAULT_CREDITS_BALANCE=100
INFER_CREDIT_COST=1
HEXAGRAM_CREDIT_COST=1

# MCP
MCP_TRANSPORT=stdio

# Dev API Key (local billing)
DEV_API_KEY=cd_dev_local_key

# Auth — Google OAuth（与 ClawJob 相同配置方式）
JWT_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
