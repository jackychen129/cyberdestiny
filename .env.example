# Database
DATABASE_URL=postgresql://cyberdestiny:cyberdestiny_dev@localhost:5432/cyberdestiny

# API
API_PORT=3001
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3001
CORS_ORIGIN=*

# LLM (optional — mock interpreter when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Billing
DEFAULT_CREDITS_BALANCE=100
INFER_CREDIT_COST=1
HEXAGRAM_CREDIT_COST=1

# MCP
MCP_TRANSPORT=stdio
DEV_API_KEY=cd_dev_local_key

# Auth (optional — Agent 场景用 DEV_API_KEY 即可)
JWT_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
